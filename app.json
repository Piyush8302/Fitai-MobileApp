{
  "expo": {
    "name": "FitAI",
    "slug": "FitAI",
    "version": "1.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F4F5FB"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#F4F5FB"
      },
      "edgeToEdgeEnabled": true,
      "softwareKeyboardLayoutMode": "adjustResize",
      "package": "com.piyush.fitai",
      "googleServicesFile": "./google-services.json",
      "backgroundColor": "#F4F5FB",
      "useNextNotificationsApi": true,
      "intentFilters": [
        {
          "action": "VIEW",
          "data": [{ "scheme": "upi" }],
          "category": ["DEFAULT", "BROWSABLE"]
        }
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "scheme": "fitai",
    "plugins": [
      "expo-font",
      "expo-web-browser",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#6C63FF",
          "defaultChannel": "default",
          "enableBackgroundRemoteNotifications": true
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow FitAI to access your photos for profile picture."
        }
      ],
      [
        "@react-native-voice/voice",
        {
          "microphonePermission": "Allow FitAI to use the microphone for voice meal logging.",
          "speechRecognitionPermission": "Allow FitAI to recognize speech for voice meal logging."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow FitAI to use the camera to scan gym QR codes for attendance."
        }
      ],
      "./plugins/withJetifier",
      "./plugins/withSpeechRecognition"
    ],
    "extra": {
      "eas": {
        "projectId": "916ee620-b417-48cf-af6a-eb71ad958f29"
      }
    },
    "owner": "piyushyadavoo7"
  }
}
