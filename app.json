{
  "expo": {
    "name": "FitAI",
    "slug": "FitAI",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0D0D1A"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0D0D1A"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.piyush.fitai",
      "backgroundColor": "#0D0D1A"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "scheme": "fitai",
    "plugins": [
      "expo-font",
      "expo-web-browser"
    ],
    "extra": {
      "eas": {
        "projectId": "916ee620-b417-48cf-af6a-eb71ad958f29"
      }
    },
    "owner": "piyushyadavoo7"
  }
}
